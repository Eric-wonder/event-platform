# 数据库（MySQL）
MYSQL_ROOT_PASSWORD=YourStrongPassword@2026
DATABASE_URL="mysql://root:YourStrongPassword@mysql-db:3306/event_platform"

# JWT
JWT_SECRET=change_this_to_a_long_random_string_at_least_32_characters
JWT_EXPIRES_IN=7d

# 服务
PORT=3000
NODE_ENV=production
FRONTEND_URL=http://your-domain.com

# 文件上传（字节，5MB）
MAX_FILE_SIZE=5242880

# 管理员初始密码（首次部署后自动失效）
ADMIN_INIT_PASSWORD=Admin@123456

# ─── 邮件服务（QQ SMTP）───────────────────────────────────
# SMTP_HOST: QQ邮箱固定为 smtp.qq.com
SMTP_HOST=smtp.qq.com
# SMTP_PORT: 465（SSL）或 587（TLS）
SMTP_PORT=465
# SMTP_USER: 你的 QQ 邮箱地址，如 123456789@qq.com
SMTP_USER=your-email@qq.com
# SMTP_PASS: QQ 邮箱授权码（非登录密码）
# 获取方式：QQ邮箱网页版 → 设置 → 账户 → POP3/IMAP/Exchange服务 → 生成授权码
SMTP_PASS=your-auth-code-here

# ─── 微信支付 ─────────────────────────────────────────────
# 商户号（在微信支付商户平台申请）
WX_MCHID=your-mchid
# 商户证书序列号（微信支付商户平台 → API安全 → 证书 → 序列号）
WX_SERIAL_NO=your-serial-no
# 商户私钥内容（rsa_private_key.pem 的完整文本，或绝对路径）
# 注意：需要用 PKCS#8 格式私钥（微信支付 v3 使用）
WX_PRIVATE_KEY=your-private-key-content-or-path
# APIv3 密钥（微信支付商户平台 → API安全 → APIv3密钥 → 设置密钥）
WX_APIV3_KEY=your-apiv3-key
# 公众号/小程序 AppID（用于 JSAPI 支付，公众号在微信公众平台申请）
WX_APPID=your-appid
# 支付回调地址（微信支付成功后通知此 URL，需 HTTPS，外网可访问）
# 示例：https://your-domain.com/api/pay/notify
WX_PAY_NOTIFY_URL=https://your-domain.com/api/pay/notify
# 沙箱模式（设为 1 启用，开发调试用，无需真实商户号）
WX_SANDBOX=0
# 微信支付 API 基础地址（通常不需要修改）
# 生产：https://api.mch.weixin.qq.com
# 沙箱：https://api.mch.weixin.qq.com/sandboxnew
WX_API_BASE=https://api.mch.weixin.qq.com
